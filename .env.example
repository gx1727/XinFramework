# XinFramework 环境变量配置
# 复制此文件为 .env 并填写实际值
# 环境变量会覆盖 config.yaml 中的对应配置

# App
XIN_APP_NAME=xin-framework
XIN_APP_ENV=dev
XIN_APP_HOST=0.0.0.0
XIN_APP_PORT=8080

# Database (PostgreSQL)
XIN_DB_HOST=localhost
XIN_DB_PORT=5432
XIN_DB_USER=postgres
XIN_DB_PASSWORD=postgres
XIN_DB_NAME=xin
XIN_DB_SSLMODE=disable

# Redis
XIN_REDIS_HOST=localhost
XIN_REDIS_PORT=6379
XIN_REDIS_PASSWORD=
XIN_REDIS_DB=0

# JWT
XIN_JWT_SECRET=your-secret-key
XIN_JWT_EXPIRE=3600
XIN_JWT_REFRESH_EXPIRE=86400

# SaaS
XIN_SAAS_MODE=shared

# Log
XIN_LOG_DIR=logs
XIN_LOG_LEVEL=info
