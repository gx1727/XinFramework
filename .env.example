# XinFramework 环境变量配置
# 复制此文件为 .env 并填写实际值
# 环境变量会覆盖 config.yaml 中的对应配置

# App
APP_NAME=xin-framework
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8080

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=xin
DB_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=your-secret-key
JWT_EXPIRE=3600
JWT_REFRESH_EXPIRE=86400

# SaaS
SAAS_MODE=shared

# Log
LOG_DIR=logs
LOG_LEVEL=info
