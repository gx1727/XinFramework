---
interface Props {
	size?: 'sm' | 'md' | 'lg';
}

const { size = 'md' } = Astro.props;

const sizes = {
	sm: { width: 60, height: 24 },
	md: { width: 80, height: 32 },
	lg: { width: 100, height: 40 },
};

const { width, height } = sizes[size];
---

<svg
	width={width}
	height={height}
	viewBox="0 0 100 40"
	fill="none"
	xmlns="http://www.w3.org/2000/svg"
	class="logo"
>
	<text
		x="0"
		y="32"
		font-family="system-ui, -apple-system, sans-serif"
		font-size="32"
		font-weight="700"
		fill="currentColor"
	>
		xin
	</text>
</svg>

<style>
	.logo {
		color: var(--text-primary);
		transition: color 0.3s ease;
	}

	:global([data-theme="dark"]) .logo {
		color: var(--text-primary);
	}
</style>
