---
import { SITE_TITLE, SITE_GITHUB } from '../consts';
import HeaderLink from './HeaderLink.astro';
import Logo from './Logo.astro';
import ThemeToggle from './ThemeToggle.astro';

const BASE_URL = import.meta.env.BASE_URL;
---


<header>
	<nav>
		<div class="nav-left">
			<a href={`${BASE_URL}/`} class="logo-link">
				<Logo size="sm" />
			</a>
		</div>
		<div class="nav-center">
			<HeaderLink href={`${BASE_URL}/`}>首页</HeaderLink>
			<HeaderLink href={`${BASE_URL}/blog`}>博客</HeaderLink>
			<HeaderLink href={`${BASE_URL}/about`}>关于</HeaderLink>
		</div>
		<div class="nav-right">
			<ThemeToggle />
			<a href={SITE_GITHUB} target="_blank" rel="noopener noreferrer" class="github-link" title="GitHub">
				<svg viewBox="0 0 16 16" width="24" height="24" aria-hidden="true">
					<path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path>
				</svg>
			</a>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--bg-primary);
		border-bottom: 1px solid var(--border-color);
		position: sticky;
		top: 0;
		z-index: 100;
		transition: background-color 0.3s ease;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1200px;
		margin: 0 auto;
		height: 64px;
	}

	.nav-left,
	.nav-center,
	.nav-right {
		display: flex;
		align-items: center;
		gap: 0.5em;
	}

	.logo-link {
		display: flex;
		align-items: center;
		padding: 0.5em;
		color: var(--text-primary);
		transition: opacity 0.2s ease;
	}

	.logo-link:hover {
		opacity: 0.8;
		text-decoration: none;
	}

	.nav-center :global(a) {
		padding: 0.5em 1em;
		color: var(--text-secondary);
		border-bottom: 2px solid transparent;
		transition: all 0.2s ease;
	}

	.nav-center :global(a):hover {
		color: var(--text-primary);
		text-decoration: none;
	}

	.nav-center :global(a.active) {
		color: var(--accent);
		border-bottom-color: var(--accent);
	}

	.github-link {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		padding: 8px;
		color: var(--text-secondary);
		border-radius: 8px;
		transition: all 0.2s ease;
	}

	.github-link:hover {
		color: var(--text-primary);
		background: var(--bg-secondary);
		text-decoration: none;
	}

	@media (max-width: 720px) {
		nav {
			gap: 0;
		}

		.nav-center {
			gap: 0;
		}

		.nav-center :global(a) {
			padding: 0.5em 0.75em;
		}
	}
</style>
