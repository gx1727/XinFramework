# XinFramework 环境变量配置
# 复制此文件为 .env 并填写实际值
# 环境变量会覆盖 config.yaml 中的对应配置

# App
XIN_APP_NAME=xin-framework
XIN_APP_ENV=dev
XIN_APP_HOST=0.0.0.0
XIN_APP_PORT=8080

# Database (PostgreSQL)
XIN_DB_HOST=localhost
XIN_DB_PORT=5432
XIN_DB_USER=postgres
XIN_DB_PASSWORD=postgres
XIN_DB_NAME=xin
XIN_DB_SSLMODE=disable
XIN_DB_MAX_OPEN_CONNS=100
XIN_DB_MAX_IDLE_CONNS=20
XIN_DB_CONN_MAX_LIFETIME_SEC=300
XIN_DB_CONN_MAX_IDLE_TIME_SEC=60

# Redis
XIN_REDIS_HOST=localhost
XIN_REDIS_PORT=6379
XIN_REDIS_PASSWORD=
XIN_REDIS_DB=0
XIN_REDIS_ENABLED=true
XIN_REDIS_REQUIRED=false
XIN_REDIS_POOL_SIZE=20
XIN_REDIS_MIN_IDLE_CONNS=5
XIN_REDIS_POOL_TIMEOUT_SEC=4
XIN_REDIS_IDLE_TIMEOUT_SEC=300
XIN_REDIS_MAX_CONN_AGE_SEC=0

# JWT
XIN_JWT_SECRET=your-secret-key
XIN_JWT_EXPIRE=3600
XIN_JWT_REFRESH_EXPIRE=86400

# SaaS
XIN_SAAS_MODE=shared

# Domain switch (comma-separated): system,cms,weixin
XIN_DOMAIN=system,cms,weixin

# Log
XIN_LOG_DIR=logs
XIN_LOG_LEVEL=info

# Bootstrap (仅首次启动时生效：创建初始 super_admin 账号)
# 设置后服务启动时会创建/更新账号并写入 account_roles(super_admin)，
# 同时在 users 表中把该账号绑定到 XIN_BOOTSTRAP_TENANT_CODE 指向的租户，
# 这样 LoginIdentity 才能查到 users 行（否则登录会报"用户未绑定任何租户"）。
# 生产环境完成引导后请清空这些变量！
# XIN_BOOTSTRAP_TOKEN=please-change-me-to-a-32+char-secret
# XIN_BOOTSTRAP_ACCOUNT=root
# XIN_BOOTSTRAP_PASSWORD=change-me-please
# XIN_BOOTSTRAP_REAL_NAME=System Root
# XIN_BOOTSTRAP_ROLE=super_admin
# XIN_BOOTSTRAP_TENANT_CODE=default
